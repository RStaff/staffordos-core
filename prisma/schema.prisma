// StaffordOS – Abando Client Command Center v1
// Prisma 7-compatible schema

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

enum AbandoPlanTier {
  free
  starter
  growth
  enterprise
}

enum MerchantStatus {
  healthy
  watch
  broken
  inactive
}

enum DailyStatusFlag {
  ok
  warning
  error
}

model AbandoMerchant {
  id            String                     @id @default(cuid())
  shopDomain    String                     @unique
  displayName   String
  planTier      AbandoPlanTier
  installedAt   DateTime
  uninstalledAt DateTime?
  status        MerchantStatus             @default(healthy)
  lastSeenAt    DateTime?
  notes         String?

  dailyStats    AbandoMerchantDailyStat[]

  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
}

model AbandoMerchantDailyStat {
  id                    String           @id @default(cuid())
  merchant              AbandoMerchant   @relation(fields: [merchantId], references: [id])
  merchantId            String
  date                  DateTime
  cartsTotal            Int
  cartsAbandoned        Int
  cartsRecovered        Int
  recoveryRate          Float
  revenueRecoveredCents Int
  exportOk              Boolean
  errorsCount           Int
  statusFlag            DailyStatusFlag

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([merchantId, date])
  @@index([date])
}


model HomeBaseNote {
  id         String   @id
  title      String
  body       String
  category   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([category, createdAt])
  @@index([createdAt])
}


model HomeBaseEvent {
  id          String   @id
  title       String
  startsAt    DateTime
  endsAt      DateTime?
  category    String
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([startsAt])
  @@index([category, startsAt])
}

model AbandoWebhookEvent {
  id             String   @id
  shopDomain     String
  topic          String
  shopifyEventId String?
  payloadJson    String
  receivedAt     DateTime @default(now())
  processedAt    DateTime?
  status         String
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([shopDomain, receivedAt])
  @@index([topic, receivedAt])
  @@index([shopifyEventId])
  @@index([status, receivedAt])
}

model AbandoNotificationEvent {
  id                String   @id
  merchantId        String
  shopDomain        String
  channel           String
  templateKey       String
  recipient         String?
  status            String
  providerMessageId String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime @default(now())

  @@index([merchantId, createdAt])
  @@index([shopDomain, createdAt])
  @@index([status, createdAt])
  @@index([channel, createdAt])
}

model AbandoRecoveryEvent {
  id                    String   @id
  merchantId            String
  shopDomain            String
  cartId                String?
  checkoutId            String?
  customerId            String?
  orderId               String?
  cartValueCents        Int      @default(0)
  status                String
  detectedAt            DateTime @default(now())
  messageSentAt         DateTime?
  recoveredAt           DateTime?
  recoveredRevenueCents Int      @default(0)
  playbook              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime

  @@index([merchantId, detectedAt])
  @@index([shopDomain, detectedAt])
  @@index([status, detectedAt])
  @@index([recoveredAt])
}

model AbandoMerchantHealth {
  id                 String   @id
  merchantId         String
  shopDomain         String   @unique
  status             String
  lastWebhookAt      DateTime?
  lastRecoveryAt     DateTime?
  lastNotificationAt DateTime?
  openIssueCount     Int      @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime

  @@index([merchantId])
  @@index([status, updatedAt])
}
